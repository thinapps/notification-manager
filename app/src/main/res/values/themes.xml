<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:buttonStyle">@style/AppButton</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowBackground">@color/app_background</item>
    </style>

    <style name="AppButton" parent="@android:style/Widget.Material.Button">
        <item name="android:background">@drawable/app_button_background</item>
        <item name="android:textColor">@color/button_text</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingStart">@dimen/button_horizontal_padding</item>
        <item name="android:paddingEnd">@dimen/button_horizontal_padding</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="StatusLabelText" parent="@android:style/Widget.TextView">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/body_text_size</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="StatusValueText" parent="@android:style/Widget.TextView">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/body_text_size</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>
