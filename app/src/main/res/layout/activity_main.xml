<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/title_text_size"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/summaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_small"
            android:text="@string/home_summary"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/body_text_size" />

        <LinearLayout
            android:id="@+id/deviceStatusCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_large"
            android:background="@drawable/app_row_background"
            android:orientation="vertical"
            android:padding="@dimen/app_row_padding">

            <TextView
                android:id="@+id/deviceStatusTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/device_status_title"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/app_label_text_size"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/deviceStatusSummaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_small"
                android:text="@string/device_status_summary"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/package_text_size" />

            <TextView
                android:id="@+id/soundModeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_medium"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="@dimen/status_row_vertical_padding"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/body_text_size" />

            <TextView
                android:id="@+id/doNotDisturbText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="@dimen/status_row_vertical_padding"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/body_text_size" />

            <TextView
                android:id="@+id/ringVolumeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="@dimen/status_row_vertical_padding"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/body_text_size" />

            <TextView
                android:id="@+id/notificationVolumeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="@dimen/status_row_vertical_padding"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/body_text_size" />

            <TextView
                android:id="@+id/alarmVolumeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="@dimen/status_row_vertical_padding"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/body_text_size" />

            <TextView
                android:id="@+id/callVolumeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="@dimen/status_row_vertical_padding"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/body_text_size" />

            <TextView
                android:id="@+id/mediaVolumeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="@dimen/status_row_vertical_padding"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/body_text_size" />

            <TextView
                android:id="@+id/systemVolumeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="@dimen/status_row_vertical_padding"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/body_text_size" />

            <TextView
                android:id="@+id/accessibilityVolumeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="@dimen/status_row_vertical_padding"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/body_text_size" />

            <TextView
                android:id="@+id/keypadToneVolumeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="@dimen/status_row_vertical_padding"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/body_text_size" />

            <LinearLayout
                android:id="@+id/deviceStatusButtonRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_medium"
                android:orientation="vertical">

                <Button
                    android:id="@+id/soundSettingsButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/button_row_gap"
                    android:text="@string/open_sound_settings" />

                <Button
                    android:id="@+id/doNotDisturbSettingsButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/button_row_gap"
                    android:text="@string/open_do_not_disturb_settings" />

                <Button
                    android:id="@+id/systemSettingsButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/open_system_notifications" />
            </LinearLayout>
        </LinearLayout>

        <EditText
            android:id="@+id/searchInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_large"
            android:hint="@string/search_apps_hint"
            android:inputType="text"
            android:singleLine="true"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <TextView
            android:id="@+id/countText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_medium"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/body_text_size" />

        <TextView
            android:id="@+id/emptyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_large"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/body_text_size"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/appList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_large"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
